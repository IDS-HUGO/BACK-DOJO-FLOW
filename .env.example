APP_NAME=DojoFlow API
APP_ENV=development
SECRET_KEY=change_this_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FRONTEND_BASE_URL=http://localhost:5173
RESET_PASSWORD_EXPIRE_MINUTES=30
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=dojoflow
CORS_ORIGINS=http://localhost:5173

# Gmail SMTP (envío de credenciales para alumnos)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# PayPal - SANDBOX local para pruebas
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_SUCCESS_URL=http://localhost:5173/app/payments
PAYPAL_CANCEL_URL=http://localhost:5173/app/payments
PAYPAL_PLAN_SUCCESS_URL=http://localhost:5173/app/plans
PAYPAL_PLAN_CANCEL_URL=http://localhost:5173/app/plans

